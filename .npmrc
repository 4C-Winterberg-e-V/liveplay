# electron-builder and Electron's native modules expect a flat, npm-style
# node_modules layout. pnpm's default symlinked (isolated) store breaks
# electron-builder's dependency collection, so use the hoisted linker.
node-linker=hoisted

# npm tolerates loose peer-dependency ranges; match that so install doesn't
# hard-fail on transitive peer mismatches in the Nuxt/Electron tree.
strict-peer-dependencies=false

# Run dependency lifecycle scripts (electron, esbuild, cloudflared, ffmpeg
# installers download their binaries via postinstall). This is the pnpm 9
# default; set explicitly so a future pnpm 10 upgrade keeps working.
enable-pre-post-scripts=true
