{
  "name": "liveplay-monorepo",
  "version": "2.1.2",
  "private": true,
  "description": "LivePlay — open-source audio playback for live sound operators. Monorepo root: client (Vue/Electron) + server (C++ audio engine).",
  "license": "AGPL-3.0-only",
  "author": {
    "name": "Thomas Doukinitsas",
    "email": "creativityfilms@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tdoukinitsas/liveplay.git"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "node scripts/ensure-server.js && pnpm --filter client dev",
    "dev:client": "pnpm --filter client dev",
    "build": "node scripts/build-all.js",
    "build:clean": "node scripts/build-clean.js",
    "build:nuxt": "pnpm --filter client build",
    "build:client": "pnpm --filter client build",
    "build:client:electron": "pnpm --filter client build:electron",
    "build:electron": "pnpm run server:build && node scripts/build-server-app-mac.js && pnpm run build:client:electron",
    "install:client": "pnpm --filter client install",
    "server:configure": "cmake --preset vs2022 -S server",
    "server:build": "node scripts/build-server.js",
    "server:run": "node scripts/run-server.js",
    "dev:all": "concurrently -n server,client -c blue,green \"pnpm server:run\" \"pnpm dev:client\"",
    "version": "node scripts/version.js",
    "bump": "node scripts/version.js"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "cloudflared",
      "@ffmpeg-installer/ffmpeg",
      "@ffprobe-installer/ffprobe"
    ]
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "optionalDependencies": {
    "@oxc-parser/binding-darwin-x64": "0.94.0",
    "@oxc-transform/binding-darwin-x64": "0.94.0",
    "@oxc-minify/binding-darwin-x64": "0.94.0"
  }
}
