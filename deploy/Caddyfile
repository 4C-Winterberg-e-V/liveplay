# =====================================================================
# LivePlay — Same-Origin reverse proxy (Mode A), portable Caddy variant.
#
# Caddy serves the SPA and proxies the control API + WebSocket to the C++
# server. Because the browser only ever sees one origin, the SPA's smart
# default (window.location.origin) just works — no manual address entry.
#
# Configure via environment:
#   LIVEPLAY_SITE_ADDR    public site address. Default ':80' (plain HTTP,
#                         homelab-friendly). Set a real hostname like
#                         'liveplay.example.com' to trigger Caddy's automatic
#                         HTTPS — then /ws is upgraded to wss on the same origin
#                         automatically by the client.
#   LIVEPLAY_SERVER_ADDR  upstream C++ server as host:port, reachable from this
#                         container. Default 'host.docker.internal:4480'
#                         (server on the Docker host). Use the LAN IP otherwise.
# =====================================================================
{$LIVEPLAY_SITE_ADDR::80} {
	encode zstd gzip

	# Control API + WebSocket → C++ server (plain HTTP inside the LAN). Caddy
	# forwards WebSocket upgrades transparently.
	@control path /api/* /ws
	reverse_proxy @control {$LIVEPLAY_SERVER_ADDR:host.docker.internal:4480}

	# SPA static files with client-side routing fallback.
	root * /srv
	try_files {path} /index.html
	file_server
}
